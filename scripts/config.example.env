# ============================================================
# API Configuration — Copy this to .env and fill in your values
# ============================================================
# Step 1: cp config.example.env .env
# Step 2: Edit this file with your credentials
# Step 3: All step scripts will auto-load it (no extra setup)
# ============================================================

# ── Choose your provider ────────────────────────────────────
# Set PROVIDER="openai" to use OpenAI (leave blank/other for MiniMax)
PROVIDER=

# ── MiniMax ───────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here
BASE_URL=https://api.minimax.chat/v1
MODEL=MiniMax-M2.7

# ── OpenAI (only if PROVIDER=openai) ────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

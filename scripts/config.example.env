# ============================================================
# API Configuration — Copy this to .env and fill in your values
# ============================================================
# Step 1: cp config.example.env .env
# Step 2: Edit this file with your credentials
# Step 3: All step scripts will auto-load it (no extra setup)
# ============================================================

# Required
API_KEY=your_api_key_here

# Optional (defaults shown below)
BASE_URL=https://api.minimax.chat/v1
MODEL=MiniMax-M2.7

# ── Example: OpenAI ──────────────────────────────────────────────
# API_KEY=sk-...
# BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o

# ── Example: Ollama (local) ──────────────────────────────────────
# API_KEY=ollama
# BASE_URL=http://localhost:11434/v1
# MODEL=llama3
